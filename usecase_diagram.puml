@startuml UseCase_SMK_Dua_Mei

skinparam actorStyle stick
skinparam nodesep 20
skinparam ranksep 35

skinparam usecase {
  BackgroundColor White
  BorderColor Black
  FontSize 10
  FontColor Black
}
skinparam actor {
  FontSize 11
  FontColor Black
  BorderColor Black
}
skinparam ArrowColor Black
skinparam ArrowThickness 1
skinparam rectangle {
  BorderColor Black
  FontSize 13
  FontStyle bold
  BackgroundColor White
}
skinparam package {
  BorderColor #333333
  BackgroundColor #F0F4FF
  FontSize 10
  FontStyle bold
}

left to right direction

title \nDiagram Use Case — Sistem Pemesanan & Pengadaan Barang\nSMK Dua Mei\n

' ══ AKTOR KIRI ══════════════════
actor "Guru" as guru
actor "Admin IT" as adminit

' ══ SISTEM ══════════════════════
rectangle "Sistem Pemesanan & Pengadaan Barang — SMK Dua Mei" {

  package "Tahap 1 · Autentikasi" {
    usecase "Login ke Sistem" as UC01
  }

  package "Tahap 2 · Pengajuan" {
    usecase "Ajukan Pemesanan\nBarang" as UC02
    usecase "Ajukan Pengadaan\nBarang" as UC03
  }

  package "Tahap 3 · Persetujuan" {
    usecase "Setujui Permintaan" as UC04
    usecase "Tolak Permintaan" as UC05
    usecase "Revisi Pemesanan" as UC06
  }

  package "Tahap 4 · Pemrosesan" {
    usecase "Proses Permintaan\nyang Disetujui" as UC07
    usecase "Selesaikan\nPermintaan" as UC08
  }

  package "Tahap 5 · Monitoring" {
    usecase "Lihat Notifikasi" as UC09
    usecase "Lihat Riwayat\nPermintaan" as UC10
    usecase "Lihat Katalog\nBarang" as UC11
  }

  package "Tahap 6 · Manajemen" {
    usecase "Lihat Dashboard\n& Statistik" as UC12
    usecase "Kelola Stok\nBarang" as UC13
    usecase "Cetak / Export\nLaporan" as UC14
  }

  package "Tahap 7 · Administrasi" {
    usecase "Kelola Akun\nPengguna" as UC15
  }

  ' ─── include / extend ─────────
  UC06 .> UC02 : <<extend>>\n(jika ditolak)
  UC07 .> UC04 : <<include>>
  UC08 .> UC07 : <<include>>
  UC09 .> UC10 : <<include>>

}

' ══ AKTOR KANAN ═════════════════
actor "Kepala Sekolah" as kepsek
actor "Admin TU" as admin

' ══ RELASI GURU ══════════════════════
guru --> UC01
guru --> UC02
guru --> UC03
guru --> UC06
guru --> UC09
guru --> UC10
guru --> UC11

' ══ RELASI ADMIN IT ══════════════════
adminit --> UC01
adminit --> UC02
adminit --> UC03
adminit --> UC07
adminit --> UC08
adminit --> UC09
adminit --> UC10
adminit --> UC11
adminit --> UC12
adminit --> UC13
adminit --> UC14
adminit --> UC15

' ══ RELASI KEPALA SEKOLAH ════════════
UC01 <-- kepsek
UC04 <-- kepsek
UC05 <-- kepsek
UC09 <-- kepsek
UC10 <-- kepsek
UC11 <-- kepsek
UC12 <-- kepsek
UC13 <-- kepsek
UC14 <-- kepsek

' ══ RELASI ADMIN TU ══════════════════
UC01 <-- admin
UC02 <-- admin
UC03 <-- admin
UC07 <-- admin
UC08 <-- admin
UC09 <-- admin
UC10 <-- admin
UC11 <-- admin
UC12 <-- admin
UC13 <-- admin
UC14 <-- admin

@enduml
